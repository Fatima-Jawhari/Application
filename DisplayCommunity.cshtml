                        <a href="#" class="d-flex align-items-center fw-600 text-grey-900 text-dark lh-26 font-xssss comment-link" data-post-id="@post.PostId">
                            <i class="feather-message-circle text-dark text-grey-900 btn-round-sm font-lg"></i>
                            <span class="d-none-xss comment-count" data-post-id="@post.PostId">@post.CommentCount Comment</span>
                        </a>

                        <a href="javascript:void(0);" class="save-btn d-flex align-items-center ms-3 me-*" data-post-id="@post.PostId" title="Save post">
                            <i class="bi font-xss fs-1 toggle-save @(post.IsSavedByCurrentUser ? "bi-bookmark-fill text-dark" : "bi-bookmark")"></i>
                        </a>

                        <div class="share-wrapper position-relative">
                            <a href="#" class="shareBtn ms-auto d-flex align-items-center fw-600 text-grey-900 text-dark lh-26 font-xssss" data-postid="@post.PostId">
                                <i class="feather-share-2 text-grey-900 text-dark btn-round-sm font-lg ms-1"></i>
                                <span class="d-none-xs ms-1">Share</span>
                            </a>

                            <div class="shareCatalog share-catalog rounded-xxl shadow-lg p-3" style="display: none;" data-postid="@post.PostId">
                                <h4 class="fw-700 font-xssss text-grey-500 mb-2">Copy Link</h4>
                                <div class="d-flex align-items-center">
                                    <input type="text" readonly value="@Url.Action("Show", "Post", new { postId = post.PostId }, protocol: Context.Request.Scheme)" class="copy-link-input bg-grey text-grey-500 font-xssss border-0 lh-32 p-2 fw-600 rounded-3 w-100 me-2" />
                                    <i class="feather-copy font-xs text-grey-500 copy-icon" style="cursor: pointer;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/feather-icons"></script>
    <script>feather.replace();</script>

    <script>
        // Enhanced notification function
        function showNotification(message, type = 'success', duration = 3000) {
            const notification = document.createElement("div");
            notification.className = `notification-popup ${type}`;
            notification.innerHTML = `
                <div style="display: flex; align-items: center; gap: 12px;">
                    <span style="font-size: 20px;">${type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️'}</span>
                    <span>${message}</span>
                </div>
            `;
            document.body.appendChild(notification);
            
            // Trigger show animation
            setTimeout(() => notification.classList.add('show'), 100);
            
            // Hide after specified duration
            setTimeout(() => {
                notification.classList.add('hide');
                setTimeout(() => notification.remove(), 400);
            }, duration);
        }

        // Enhanced copy to clipboard functionality
        document.getElementById("copyCommunityLink").addEventListener("click", function(e) {
            e.preventDefault();
            const url = this.getAttribute("data-url");
            navigator.clipboard.writeText(url).then(() => {
                showNotification("Community URL copied to clipboard! 🎉");
            }).catch(err => {
                showNotification("Failed to copy the URL", 'error');
            });
        });

        // Enhanced loading states
        function showLoading(element) {
            const originalContent = element.innerHTML;
            element.innerHTML = `<div class="spinner-border spinner-border-sm me-2" role="status"></div>Loading...`;
            element.disabled = true;
            return originalContent;
        }

        function hideLoading(element, originalContent) {
            element.innerHTML = originalContent;
            element.disabled = false;
        }
    </script>

    <script>
        $(document).on('click', '.join-btn', function() {
            const $btn = $(this);
            const communityId = $btn.data('community-id');
            const token = $('#__RequestVerificationToken').val();
            
            const originalContent = showLoading($btn[0]);
            
            $.ajax({
                url: '@Url.Action("ToggleJoin", "Community")',
                type: 'POST',
                data: { communityId: communityId, __RequestVerificationToken: token },
                success: function(res) {
                    if (res.joining) {
                        $btn.removeClass('btn-primary').addClass('btn-outline-primary').text('Leave');
                        $('#groupChatForm').show();
                        $('#addPostBtn').show();
                        showNotification("Welcome to the community! 🎉");
                    } else {
                        $btn.removeClass('btn-outline-primary').addClass('btn-primary').text('Join');
                        $('#groupChatForm').hide();
                        $('#addPostBtn').hide();
                        showNotification("You've left the community", 'info');
                    }
                    $('#memberCount').text(res.memberCount);
                },
                error: function() {
                    showNotification("Failed to update community membership", 'error');
                },
                complete: function() {
                    hideLoading($btn[0], $btn.hasClass('btn-outline-primary') ? 'Leave' : 'Join');
                }
            });
        });
    </script>

    <script src="~/js/plugin.js"></script>
    <script src="~/js/lightbox.js"></script>
    <script src="~/js/scripts.js"></script>
    <script src="https://meet.jit.si/external_api.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const shareButtons = document.querySelectorAll(".shareBtn");
            const copyIcons = document.querySelectorAll(".copy-icon");

            shareButtons.forEach(btn => {
                btn.addEventListener("click", function(e) {
                    e.preventDefault();
                    document.querySelectorAll(".shareCatalog").forEach(catalog => {
                        if (catalog !== btn.parentElement.querySelector('.shareCatalog')) {
                            catalog.style.display = "none";
                        }
                    });
                    const catalog = btn.parentElement.querySelector('.shareCatalog');
                    if (!catalog) return;
                    catalog.style.display = (catalog.style.display === "block") ? "none" : "block";
                });
            });

            copyIcons.forEach(icon => {
                icon.addEventListener("click", function() {
                    const input = icon.closest(".shareCatalog").querySelector(".copy-link-input");
                    input.select();
                    input.setSelectionRange(0, 99999);
                    
                    if (navigator.clipboard && window.isSecureContext) {
                        navigator.clipboard.writeText(input.value).then(() => {
                            showNotification("Link copied to clipboard! 📋");
                            // Visual feedback
                            const originalBackground = icon.style.background;
                            icon.style.background = "linear-gradient(135deg, #10b981 0%, #059669 100%)";
                            icon.style.transform = "scale(1.2)";
                            setTimeout(() => {
                                icon.style.background = originalBackground;
                                icon.style.transform = "scale(1)";
                            }, 300);
                        });
                    } else {
                        try {
                            document.execCommand("copy");
                            showNotification("Link copied! 📋");
                        } catch {
                            showNotification("Copy not supported", 'error');
                        }
                    }
                });
            });

            document.addEventListener("click", function(event) {
                if (!event.target.closest(".share-wrapper")) {
                    document.querySelectorAll(".shareCatalog").forEach(catalog => {
                        catalog.style.display = "none";
                    });
                }
            });
        });
    </script>

    <script>
        $(document).on('click', '.like-btn', function() {
            const $btn = $(this);
            const postId = $btn.data('post-id');
            const $icon = $btn.find('.toggle-heart');
            const $count = $(`.like-count[data-post-id="${postId}"]`);
            
            // Optimistic UI update
            const isCurrentlyLiked = $icon.hasClass('bi-heart-fill');
            if (isCurrentlyLiked) {
                $icon.removeClass('bi-heart-fill text-danger').addClass('bi-heart');
                $count.text(parseInt($count.text()) - 1);
            } else {
                $icon.removeClass('bi-heart').addClass('bi-heart-fill text-danger');
                $count.text(parseInt($count.text()) + 1);
            }
            
            $.post('@Url.Action("ToggleLike", "Home")', { postId: postId }, function(res) {
                // Update with actual server response
                if (res.liked) {
                    $icon.removeClass('bi-heart').addClass('bi-heart-fill text-danger');
                } else {
                    $icon.removeClass('bi-heart-fill text-danger').addClass('bi-heart');
                }
                $count.text(res.likeCount);
            }).fail(function() {
                // Revert on failure
                if (isCurrentlyLiked) {
                    $icon.removeClass('bi-heart').addClass('bi-heart-fill text-danger');
                    $count.text(parseInt($count.text()) + 1);
                } else {
                    $icon.removeClass('bi-heart-fill text-danger').addClass('bi-heart');
                    $count.text(parseInt($count.text()) - 1);
                }
                showNotification("Failed to update like status", 'error');
            });
        });
    </script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $(document).on('click', '.like-count.clickable', function(e) {
                e.stopPropagation();
                const postId = $(this).data('post-id');
                if (!postId) {
                    showNotification("Post ID not found!", 'error');
                    return;
                }

                $('.likers-popup').remove();
                const popup = $(`
                    <div class="likers-popup shadow rounded bg-white border glass-effect" 
                         style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1050;width:90%;max-width:600px;height:400px;overflow:hidden;border-radius:var(--border-radius-xl);box-shadow:var(--shadow-xl);animation:slideInScale 0.3s ease-out;">
                        <div style="background:var(--teal-gradient);padding:24px;border-radius:var(--border-radius-xl) var(--border-radius-xl) 0 0;">
                            <h5 class="text-center mb-0" style="color:white;font-weight:700;font-size:1.2rem;">❤️ Likes</h5>
                        </div>
                        <div class="likers-list text-center" style="padding:28px;overflow-y:auto;height:calc(100% - 88px);">
                            <div class="d-flex align-items-center justify-content-center loading-shimmer" style="min-height:60px;border-radius:12px;">
                                <div class="spinner-border spinner-border-sm me-2" role="status" style="color:var(--primary-teal);"></div>
                                Loading...
                            </div>
                        </div>
                    </div>
                `);
                $('body').append(popup);

                $.get('@Url.Action("GetLikersForPost", "Home")', { postId: postId }, function(likers) {
                    const listContainer = popup.find('.likers-list');
                    if (!likers || likers.length === 0) {
                        listContainer.html(`
                            <div class="text-center text-muted">
                                <div style="font-size:4rem;margin-bottom:16px;opacity:0.6;">💔</div>
                                <div style="font-size:18px;font-weight:600;color:var(--text-secondary);">No likes yet</div>
                                <div style="font-size:14px;color:var(--text-muted);margin-top:8px;">Be the first to show some love!</div>
                            </div>
                        `);
                        return;
                    }

                    const list = $('<ul class="list-unstyled mb-0"></ul>');
                    likers.forEach(liker => {
                        const img = liker.profilePictureUrl || '/images/default-profile.png';
                        list.append(`
                            <li class="d-flex align-items-center mb-3" style="padding:16px;border-radius:var(--border-radius);transition:all 0.3s ease;border:1px solid var(--border-light);">
                                <img src="${img}" class="rounded-circle me-3" style="width:48px;height:48px;object-fit:cover;border:3px solid var(--border-light);">
                                <span class="fw-semibold" style="color:var(--text-primary);font-size:16px;">${liker.username}</span>
                            </li>
                        `);
                    });
                    listContainer.html(list);
                    
                    list.find('li').hover(function() {
                        $(this).css({
                            'background': 'var(--surface-light)',
                            'transform': 'translateX(4px)',
                            'border-color': 'var(--primary-teal)'
                        });
                    }, function() {
                        $(this).css({
                            'background': 'transparent',
                            'transform': 'translateX(0)',
                            'border-color': 'var(--border-light)'
                        });
                    });
                }).fail(function() {
                    popup.find('.likers-list').html(`
                        <div class="text-center text-muted">
                            <div style="color:#ef4444;font-size:18px;">❌ Failed to load likes</div>
                            <div style="font-size:14px;margin-top:8px;color:var(--text-muted);">Please try again later</div>
                        </div>
                    `);
                });

                $(window).on('scroll.likersPopup', function() {
                    popup.remove();
                    $(window).off('scroll.likersPopup');
                    $(document).off('click.likersPopup');
                });

                $(document).on('click.likersPopup', function() {
                    popup.remove();
                    $(window).off('scroll.likersPopup');
                    $(document).off('click.likersPopup');
                });
            });
        });
    </script>

    <script>
        $(document).ready(function() {
            $(document).on('click', '.comment-link', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const postId = $(this).data('post-id');

                $('.comments-popup, .comments-backdrop').remove();
                const backdrop = $('<div class="comments-backdrop"></div>');
                $('body').append(backdrop);

                const popup = $(`
                    <div class="comments-popup">
                        <div class="comments-header">
                            <h5 class="text-center mb-0">💬 Comments</h5>
                            <button class="close-popup"></button>
                        </div>
                        <ul class="comments-list">
                            <div class="text-center text-muted d-flex align-items-center justify-content-center loading-shimmer" style="min-height:60px;border-radius:12px;margin:20px;">
                                <div class="spinner-border spinner-border-sm me-2" role="status" style="color:var(--primary-teal);"></div>
                                Loading comments...
                            </div>
                        </ul>
                        <div class="comment-input-container">
                            <textarea class="comment-textarea" placeholder="Share your thoughts..." rows="1"></textarea>
                            <button class="btn send-btn" title="Send comment" type="button">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                    <path d="m22 2-7 20-4-9-9-4 20-7z"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                `);
                $('body').append(popup);

                function closePopup() {
                    popup.fadeOut(200, function() {
                        popup.remove();
                        backdrop.remove();
                    });
                }

                popup.find('.close-popup').on('click', closePopup);
                backdrop.on('click', closePopup);
                $(document).on('keydown.commentPopup', function(e) {
                    if (e.key === 'Escape') {
                        closePopup();
                        $(document).off('keydown.commentPopup');
                    }
                });

                popup.find('.comment-textarea').on('input', function() {
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 140) + 'px';
                });

                function loadComments() {
                    $.get('@Url.Action("GetCommentsForPost", "Home")', { postId }, function(comments) {
                        if (!comments || comments.length === 0) {
                            popup.find('.comments-list').html(`
                                <div class="text-center text-muted" style="padding:40px;">
                                    <div style="font-size:4rem;margin-bottom:16px;opacity:0.6;">💭</div>
                                    <div style="font-size:18px;font-weight:600;color:var(--text-secondary);">No comments yet</div>
                                    <div style="font-size:14px;opacity:0.8;margin-top:8px;color:var(--text-muted);">Be the first to share your thoughts!</div>
                                </div>
                            `);
                            return;
                        }

                        const list = $('<ul class="list-unstyled mb-0"></ul>');
                        comments.forEach(comment => {
                            const img = comment.profilePictureUrl || '/images/default-profile.png';
                            const date = new Date(comment.createdAt).toLocaleDateString('en-US', {
                                month: 'short',
                                day: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                            });
                            list.append(`
                                <li class="comment-item">
                                    <div class="d-flex align-items-start">
                                        <img src="${img}" class="me-3" alt="${comment.username}">
                                        <div style="flex-grow:1;position:relative;padding-bottom:28px;">
                                            <strong>${comment.username}</strong>
                                            <div style="margin-top:6px;color:var(--text-secondary);line-height:1.6;font-size:15px;">${comment.content}</div>
                                            <div class="comment-date">${date}</div>
                                        </div>
                                    </div>
                                </li>
                            `);
                        });
                        popup.find('.comments-list').html(list);
                        const commentsList = popup.find('.comments-list')[0];
                        commentsList.scrollTop = commentsList.scrollHeight;
                    }).fail(function() {
                        popup.find('.comments-list').html(`
                            <div class="text-center text-muted" style="padding:40px;">
                                <div style="color:#ef4444;font-size:18px;">❌ Failed to load comments</div>
                                <div style="font-size:14px;margin-top:12px;color:var(--text-muted);">Please try again later</div>
                            </div>
                        `);
                    });
                }

                loadComments();

                function sendComment() {
                    const content = popup.find('textarea').val().trim();
                    if (!content) return;

                    const $sendBtn = popup.find('.send-btn');
                    const $textarea = popup.find('textarea');
                    
                    $sendBtn.prop('disabled', true).html(`
                        <div class="spinner-border spinner-border-sm" role="status" style="width:18px;height:18px;">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    `);

                    $.ajax({
                        url: '@Url.Action("AddComment", "Home")',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({
                            postId: postId,
                            userId: '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value',
                            content: content
                        }),
                        success: function() {
                            $textarea.val('').css('height', 'auto');
                            loadComments();
                            $.get('@Url.Action("GetCommentCount", "Home")', { postId: postId }, function(data) {
                                const count = data.count;
                                const countSpan = $(`.comment-count[data-post-id="${postId}"]`);
                                if (countSpan.length) {
                                    countSpan.text(count + (count === 1 ? " Comment" : " Comments"));
                                }
                            });
                            
                            $sendBtn.html('✓').css('background', 'linear-gradient(135deg, #10b981 0%, #059669 100%)');
                            showNotification("Comment posted! 💬");
                            setTimeout(() => {
                                $sendBtn.html(`
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="width:22px;height:22px;">
                                        <path d="m22 2-7 20-4-9-9-4 20-7z"/>
                                    </svg>
                                `).css('background', '');
                            }, 1500);
                        },
                        error: function() {
                            showNotification("Failed to post comment. Please try again.", 'error');
                        },
                        complete: function() {
                            $sendBtn.prop('disabled', false);
                        }
                    });
                }

                popup.find('.send-btn').on('click', sendComment);
                popup.find('.comment-textarea').on('keydown', function(e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        sendComment();
                    }
                });

                setTimeout(() => {
                    popup.find('.comment-textarea').focus();
                }, 300);
            });
        });
    </script>

    <script>
        $(document).on('click', '.save-btn', function() {
            const $btn = $(this);
            const postId = $btn.data('post-id');
            const $icon = $btn.find('.toggle-save');
            
            // Optimistic UI update
            const isCurrentlySaved = $icon.hasClass('bi-bookmark-fill');
            if (isCurrentlySaved) {
                $icon.removeClass('bi-bookmark-fill text-dark').addClass('bi-bookmark');
            } else {
                $icon.removeClass('bi-bookmark').addClass('bi-bookmark-fill text-dark');
            }
            
            $.post('@Url.Action("ToggleSave", "Home")', { postId: postId }, function(res) {
                if (res.isSaved) {
                    $icon.removeClass('bi-bookmark').addClass('bi-bookmark-fill text-dark');
                    showNotification("Post saved! 📌");
                } else {
                    $icon.removeClass('bi-bookmark-fill text-dark').addClass('bi-bookmark');
                    showNotification("Post unsaved", 'info');
                }
            }).fail(function() {
                // Revert on failure
                if (isCurrentlySaved) {
                    $icon.removeClass('bi-bookmark').addClass('bi-bookmark-fill text-dark');
                } else {
                    $icon.removeClass('bi-bookmark-fill text-dark').addClass('bi-bookmark');
                }
                showNotification("Failed to toggle save status. Please try again.", 'error');
            });
        });
    </script>

    <script>
        $(document).ready(function() {
            $(document).on('click', '.report-link', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const postId = $(this).data('post-id');

                $('.report-popup').remove();
                const popup = $(`
                    <style>
                        .report-popup {
                            position: fixed;
                            top: 50%;
                            left: 50%;
                            transform: translate(-50%, -50%);
                            z-index: 1050;
                            background: rgba(255, 255, 255, 0.95);
                            border-radius: var(--border-radius-xl);
                            box-shadow: var(--shadow-xl);
                            width: 360px;
                            max-width: 90%;
                            overflow: hidden;
                            animation: slideInScale 0.3s ease-out;
                            backdrop-filter: var(--backdrop-blur);
                        }
                        .report-popup .header {
                            background: var(--teal-gradient);
                            padding: 24px 28px;
                            color: white;
                            font-weight: 700;
                            text-align: center;
                            position: relative;
                            font-size: 1.1rem;
                        }
                        .report-popup ul {
                            list-style: none;
                            padding: 0;
                            margin: 0;
                        }
                        .report-popup li {
                            padding: 18px 28px;
                            cursor: pointer;
                            color: var(--text-primary);
                            font-weight: 500;
                            border-bottom: 1px solid var(--border-light);
                            transition: all 0.3s ease;
                            display: flex;
                            align-items: center;
                            font-size: 15px;
                        }
                        .report-popup li:last-child {
                            border-bottom: none;
                        }
                        .report-popup li:hover {
                            background: var(--teal-glow);
                            color: var(--primary-teal);
                            transform: translateX(6px);
                        }
                        .report-popup .close-btn {
                            position: absolute;
                            top: 18px;
                            right: 24px;
                            cursor: pointer;
                            font-size: 20px;
                            color: white;
                            background: rgba(255, 255, 255, 0.2);
                            width: 32px;
                            height: 32px;
                            border-radius: 50%;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            transition: all 0.2s ease;
                        }
                        .report-popup .close-btn:hover {
                            background: rgba(255, 255, 255, 0.3);
                            transform: scale(1.1);
                        }
                    </style>
                    <div class="report-popup">
                        <div class="header">
                            🚩 Report Post
                            <span class="close-btn">&times;</span>
                        </div>
                        <ul>
                            <li class="report-reason" data-reason="Spam or misleading">
                                <span style="margin-right:14px;font-size:18px;">📧</span>
                                Spam or misleading
                            </li>
                            <li class="report-reason" data-reason="Hate speech or symbols">
                                <span style="margin-right:14px;font-size:18px;">⚠️</span>
                                Hate speech or symbols
                            </li>
                            <li class="report-reason" data-reason="Harassment or bullying">
                                <span style="margin-right:14px;font-size:18px;">😡</span>
                                Harassment or bullying
                            </li>
                            <li class="report-reason" data-reason="Nudity or sexual content">
                                <span style="margin-right:14px;font-size:18px;">🔞</span>
                                Nudity or sexual content
                            </li>
                            <li class="report-reason" data-reason="Violence or dangerous acts">
                                <span style="margin-right:14px;font-size:18px;">⚡</span>
                                Violence or dangerous acts
                            </li>
                        </ul>
                    </div>
                `);
                $('body').append(popup);

                popup.find('.close-btn').on('click', function() {
                    popup.fadeOut(200, function() {
                        popup.remove();
                    });
                });

                popup.find('.report-reason').on('click', function() {
                    const $reason = $(this);
                    const reason = $reason.data('reason');
                    const token = $('#__RequestVerificationToken').val();

                    $reason.html(`
                        <div class="spinner-border spinner-border-sm me-2" role="status" style="color:var(--primary-teal);width:18px;height:18px;"></div>
                        Submitting...
                    `);

                    $.ajax({
                        url: '/Home/ReportPost',
                        method: 'POST',
                        data: {
                            __RequestVerificationToken: token,
                            ReportedPostId: postId,
                            Reason: reason
                        },
                        success: function() {
                            $reason.html(`
                                <span style="margin-right:14px;font-size:18px;">✅</span>
                                Report submitted successfully
                            `).css({
                                'background': 'linear-gradient(135deg, #10b981 0%, #059669 100%)',
                                'color': 'white',
                                'transform': 'none'
                            });
                            showNotification("Report submitted successfully. Thank you for keeping our community safe! 🛡️");
                            setTimeout(() => {
                                popup.fadeOut(300, function() {
                                    popup.remove();
                                });
                            }, 2000);
                        },
                        error: function() {
                            $reason.html(`
                                <span style="margin-right:14px;font-size:18px;">❌</span>
                                Something went wrong
                            `).css({
                                'background': 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)',
                                'color': 'white'
                            });
                            showNotification("Failed to submit report. Please try again.", 'error');
                            setTimeout(() => {
                                popup.fadeOut(300, function() {
                                    popup.remove();
                                });
                            }, 2500);
                        }
                    });
                });

                $(document).on('click.reportPopup', function(e) {
                    if (!$(e.target).closest('.report-popup').length) {
                        popup.fadeOut(200, function() {
                            popup.remove();
                        });
                        $(document).off('click.reportPopup');
                    }
                });
            });
        });
    </script>
}
