            <a href="#" id="dropdownMenu2" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="ti-more-alt text-grey-900 btn-round-md bg-greylight font-xss"></i>
            </a>

            <div class="dropdown-menu dropdown-menu-end p-4 rounded-xxl border-0 shadow-lg" aria-labelledby="dropdownMenu2">
                <a href="#" id="copyCommunityLink" class="d-flex align-items-center fw-600 text-grey-900 text-dark lh-26 font-xssss" data-url="@CommunityUrl">
                    <span class="d-none-xss">Share Community</span>
                </a>
            </div>
        </div>
    </div>
</div>

<div id="feedInterface" class="row feed-body">
    <div class="col-xl-10 col-xxl-10 col-lg-10">
        @if (Model.Posts == null || !Model.Posts.Any())
        {
            <div class="text-center text-muted my-5">
                <h5>No Posts Yet</h5>
                <p style="color: var(--text-light); font-size: 1.1rem;">Be the first to share something with the community!</p>
