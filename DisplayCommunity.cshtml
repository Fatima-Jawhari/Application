                        <div class="d-flex align-items-center fw-600 text-grey-900 text-dark lh-26 font-xssss me-2">
                            <a href="javascript:void(0);" class="like-btn d-flex align-items-center" data-post-id="@post.PostId">
                                <i class="bi font-xss fs-1 toggle-heart @(post.IsLikedByCurrentUser ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                            </a>
